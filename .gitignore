**/.claude/settings.local.json

# Rust / Cargo
/target
**/*.rs.bk
Cargo.lock.bak

# Stray rustc outputs at the repo root — `rustc foo.rs` without an
# explicit `-o` writes `rust_out.exe` / `rust_out.pdb` on Windows.
# All real binaries live under `target/`; anything at the repo root
# is a transcription mistake.
/rust_out.exe
/rust_out.pdb

# Stray subagent temp-file leakage at the repo root. Agents that
# write `git diff` to a Windows temp path like
# `C:\Users\<user>\AppData\Local\Temp\foo.txt` and then run the
# command from a POSIX-shell context produce a mojibaked
# filename at the repo root (the `:` and backslashes are
# preserved verbatim in a UTF-8 filesystem entry). Match any
# such accidental capture: a top-level entry whose name starts
# with a drive letter colon (`C:` etc.) or that came from a
# Temp directory.
/C\357\200\272*
/*UsersMaxAppDataLocalTemp*

# IDE
.vscode/
.idea/
*.iml

# OS
Thumbs.db
.DS_Store

# Output of the test-data generators in tools/. Each script writes
# into the CWD; running any of them from the repo root would
# otherwise litter the working tree.
test_case.cpp
test_case.rs
/test_files/
